# =========================================================================
# CONFIGURACIÓN DEL SISTEMA ÁUREA SYSTEMS - PLANTILLA DE VARIABLES DE ENTORNO
# =========================================================================
# Copia este archivo como '.env.local' (o '.env' en tu servidor de backend)
# y rellena con los valores correspondientes para tu infraestructura local.
#
# ¡ATENCIÓN! NUNCA subas el archivo con valores reales a repositorios git.
# =========================================================================

# Puerto de Ejecución del Servidor Backend (Python / FastAPI)
PORT=8000
HOST=127.0.0.1

# Configuración de Base de Datos de Telemetría (PostgreSQL / MySQL / SQLite)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aurea_telemetry
DB_USER=aurea_admin
DB_PASSWORD=YOUR_DB_SECRET_PASSWORD_HERE

# Claves de Autenticación y Cifrado
JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY_HERE
TELEMETRY_API_KEY=YOUR_EXTERNAL_TELEMETRY_TOKEN_HERE

# Configuración del Motor Matemático SFA
SFA_BASE_FREQUENCY=7.25
SFA_DEFAULT_LAMBDA=1.618

# Next.js Variables de Entorno Públicas (Leídas en el Frontend de ser necesario)
NEXT_PUBLIC_SFA_VERSION=3.0.0
NEXT_PUBLIC_ENVIRONMENT=development
