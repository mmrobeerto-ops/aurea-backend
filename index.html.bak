                                    <div class="sacred-geometry-glow" style="position: absolute; display: flex; align-items: center; justify-content: center; pointer-events: none;">
                                        <svg viewBox="0 0 100 100" class="rotating-spiral" style="width: 70px; height: 70px; animation: spin 12s linear infinite;">
                                            <path d="M 50,50 A 20,20 0 0,0 30,30 A 12,12 0 0,0 42,18 A 8,8 0 0,0 50,26 A 5,5 0 0,0 45,31" fill="none" stroke="var(--color-primary-gold)" stroke-width="2" style="filter: drop-shadow(0 0 8px var(--color-primary-gold));" />
