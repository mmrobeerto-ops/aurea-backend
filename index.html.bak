<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Áurea Systems | Armonizando el caos con precisión geométrica</title>
    <meta name="description" content="Transformamos datos caóticos en soluciones armónicas de alta eficiencia. Descubre el Motor SFA de sintonización fractal de armónicos e impacto social.">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Stylesheets -->
    <link rel="stylesheet" href="css/styles.css">
    <!-- PayPal SDK -->
    <script src="https://www.paypal.com/sdk/js?client-id=AewGtK31C24qS1dJM0IhZkl4YDrN2dNuJ0q90WGuB6kmR5sbS8e_uFrXsC2nJS0WY8MiElKh0VWfX2Io&currency=USD"></script>
</head>
<body>
    <!-- Top Core Status Bar -->
    <div class="core-status-bar">
        <div class="status-item">
            <span class="status-indicator-dot pulsing"></span>
            <span class="status-label">ESTADO DEL NÚCLEO:</span>
            <span class="status-value text-gold">CALIBRADO</span>
        </div>
    </div>

    <!-- Floating Action Button 'N' (Bottom Left) -->
    <button class="btn-floating-n" id="btn-terminal-toggle" aria-label="Consola de Telemetría">N</button>

    <!-- Interactive Telemetry Console (Hidden by default) -->
    <div class="telemetry-console" id="telemetry-console">
        <div class="console-header">
            <div class="console-dots">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
            </div>
            <span class="console-title">aurea_coaxial_telemetry.log</span>
            <button class="console-close" id="console-close-btn">&times;</button>
        </div>
        <div class="console-body" id="console-log-content">
            <div class="log-line text-gold">[INICIALIZANDO] Sintonización Fractal de Armónicos (SFA)...</div>
            <div class="log-line">[OK] Sintonía espectral establecida.</div>
            <div class="log-line">[OK] Núcleo calibrado con constante espectral lambda = 1.618.</div>
            <div class="log-line">[CONEXIÓN] Mapeando registros de telemetría en PLCs...</div>
            <div class="log-line text-blue">[OK] Servidor OPC UA activo. Escuchando tags de planta.</div>
            <div class="log-line">[OK] Acelerómetros (Vibración) sintonizados a 2.5 kHz.</div>
            <div class="log-line">[OK] Transmisores de Presión sintonizados por canal Modbus IW.</div>
            <div class="log-line text-gold">[PROCESANDO] Análisis espectral SFA en ráfaga de datos...</div>
            <div class="log-line text-green">[EFICIENCIA] Atenuación de ruido fractal completada en 0.12s.</div>
            <div class="log-line">[HISTORIA] Filosofía: "El protón invisible" - el arq. Mario Murillo.</div>
        </div>
    </div>

    <!-- Background geometric overlay -->
    <div class="bg-geometry">
        <svg viewBox="0 0 100 100" preserveAspectRatio="none">
            <circle cx="10" cy="20" r="30" class="geom-circle" />
            <circle cx="90" cy="80" r="40" class="geom-circle" />
            <path d="M-10,50 Q30,60 70,30 T110,50" class="geom-line" />
            <path d="M-10,20 Q40,10 80,40 T110,10" class="geom-line" />
        </svg>
    </div>

    <!-- Header / Navbar -->
    <header class="navbar">
        <div class="nav-container">
            <a href="#inicio" class="logo-group" id="logo-link">
                <div class="logo-text">
                    <span class="logo-title">Áurea</span>
                    <span class="logo-subtitle">SYSTEMS</span>
                    <span class="logo-tagline">OPTIMIZACIÓN FRACTAL DE ALTA VELOCIDAD</span>
                </div>
                <div class="logo-icon-wrapper">
                    <!-- Mathematically accurate Vertical Fibonacci Spiral SVG matching the image logo exactly -->
                    <svg viewBox="0 0 34 55" class="logo-spiral-svg">
                        <!-- Fibonacci Grid Squares -->
                        <rect x="0" y="0" width="34" height="34" class="grid-square" />
                        <rect x="0" y="34" width="21" height="21" class="grid-square" />
                        <rect x="21" y="42" width="13" height="13" class="grid-square" />
                        <rect x="26" y="34" width="8" height="8" class="grid-square" />
                        <rect x="21" y="34" width="5" height="5" class="grid-square" />
                        <rect x="21" y="39" width="3" height="3" class="grid-square" />
                        <rect x="24" y="40" width="2" height="2" class="grid-square" />
                        <rect x="24" y="39" width="1" height="1" class="grid-square" />
                        <rect x="25" y="39" width="1" height="1" class="grid-square" />
                        
                        <!-- Diagonal grid lines of triangulation (like the image) -->
                        <line x1="0" y1="0" x2="34" y2="34" class="grid-line" />
                        <line x1="34" y1="0" x2="0" y2="34" class="grid-line" />
                        <line x1="0" y1="34" x2="21" y2="55" class="grid-line" />
                        <line x1="21" y1="34" x2="0" y2="55" class="grid-line" />
                        
                        <!-- Rays radiating from the center of spiral (26, 40) -->
                        <line x1="26" y1="40" x2="0" y2="0" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="34" y2="0" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="34" y2="34" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="0" y2="34" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="0" y2="55" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="21" y2="55" class="grid-line-faint" />
                        <line x1="26" y1="40" x2="34" y2="55" class="grid-line-faint" />
                        
                        <!-- Spiral Path -->
                        <path d="M 34,0 A 34,34 0 0,0 0,34 A 21,21 0 0,0 21,55 A 13,13 0 0,0 34,42 A 8,8 0 0,0 26,34 A 5,5 0 0,0 21,39 A 3,3 0 0,0 24,42 A 2,2 0 0,0 26,40" class="spiral-path" />
                        
                        <!-- Cyan Dot in top-left corner -->
                        <circle cx="0" cy="0" r="1.6" class="logo-cyan-dot" />
                    </svg>
                </div>
            </a>
            
            <button class="menu-toggle" aria-label="Abrir menú" id="mobile-menu-btn">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <nav class="nav-menu" id="nav-menu">
                <a href="#mision" class="nav-link">MISIÓN</a>
                <a href="#vision" class="nav-link">VISIÓN</a>
                <a href="#servicios" class="nav-link">SERVICIOS COMERCIALES</a>
                <a href="#fundacion" class="nav-link">FUNDACIÓN</a>
                <a href="#academia" class="nav-link">ACADEMIA</a>
                <a href="#contacto" class="nav-link">CONTACTO</a>
                <a href="sensores.html" class="nav-link">SENSORES</a>

                <a href="#ecosistema" class="nav-btn">ECOSISTEMA</a>
            </nav>
        </div>
    </header>

    <main>
        <!-- HERO SECTION (INICIO) & ECOSISTEMA DUAL (COMBINED SCREEN LIKE SCREENSHOT) -->
        <section id="inicio" class="hero-section">
            <!-- Giant faint background spiral behind hero content -->
            <div class="hero-bg-spiral-wrapper">
                <svg viewBox="0 0 34 55" class="hero-bg-spiral-svg">
                    <rect x="0" y="0" width="34" height="34" class="grid-square-faint" />
                    <rect x="0" y="34" width="21" height="21" class="grid-square-faint" />
                    <rect x="21" y="42" width="13" height="13" class="grid-square-faint" />
                    <rect x="26" y="34" width="8" height="8" class="grid-square-faint" />
                    <rect x="21" y="34" width="5" height="5" class="grid-square-faint" />
                    <rect x="21" y="39" width="3" height="3" class="grid-square-faint" />
                    <rect x="24" y="40" width="2" height="2" class="grid-square-faint" />
                    
                    <line x1="0" y1="0" x2="34" y2="34" class="grid-square-faint" />
                    <line x1="34" y1="0" x2="0" y2="34" class="grid-square-faint" />
                    <line x1="0" y1="34" x2="21" y2="55" class="grid-square-faint" />
                    <line x1="21" y1="34" x2="0" y2="55" class="grid-square-faint" />

                    <path d="M 34,0 A 34,34 0 0,0 0,34 A 21,21 0 0,0 21,55 A 13,13 0 0,0 34,42 A 8,8 0 0,0 26,34 A 5,5 0 0,0 21,39 A 3,3 0 0,0 24,42 A 2,2 0 0,0 26,40" class="spiral-path-faint" />
                </svg>
            </div>

            <!-- Floating Sparkle Star (Right) -->
            <div class="sparkle-star-wrapper">
                <svg viewBox="0 0 24 24" class="sparkle-star">
                    <path d="M12 2L14.8 9.2L22 12L14.8 14.8L12 22L9.2 14.8L2 12L9.2 9.2L12 2Z" />
                </svg>
            </div>

            <div class="hero-container">
                <h1 class="hero-title">
                    OPTIMIZACIÓN PREDICTIVA Y<br>
                    <span class="text-gold font-bold">DIAGNÓSTICO ESPECTRAL AUTOMATIZADO</span>
                </h1>
                <p class="hero-subtitle">
                    Conecte la telemetría de sus activos críticos. Procese registros analógicos crudos de PLCs (Vibración, Corriente, Temperatura y Presión) y obtenga reportes técnicos con acciones de mantenimiento en segundos mediante el Motor SFA.<br>
                    <span class="hero-promo-badge" style="font-size: 0.82rem; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.4); color: #10b981; padding: 0.3rem 0.8rem; border-radius: 4px; display: inline-block; margin-top: 0.8rem; font-weight: 600; font-family: var(--font-accent); letter-spacing: 0.05em; text-transform: uppercase;">⚡ EVALUACIÓN INICIAL GRATIS ACTIVADA (CLUB 33)</span>
                </p>
                <div class="hero-actions">
                    <a href="#sfa-plataforma" class="btn btn-gold">INICIAR DIAGNÓSTICO GRATIS</a>
                    <a href="#servicios" class="btn btn-outline">VER DOCUMENTACIÓN</a>
                </div>
            </div>

            <!-- ECOSISTEMA DUAL CONTAINER -->
            <div id="ecosistema" class="ecosistema-section scroll-reveal">
                <!-- Floating status label seen in screenshot -->
                <div class="hero-status-badge">
                    <span class="status-indicator-dot pulsing"></span>
                    <span class="status-text">Núcleo: Calibrado | Ecuación 3 Activa</span>
                </div>

                <h2 class="section-title">ECOSISTEMA DUAL</h2>
                <p style="color: var(--color-text-gray); font-size: 0.88rem; max-width: 600px; margin: -1.2rem auto 2.5rem; font-family: var(--font-accent); letter-spacing: 0.05em; line-height: 1.6;">
                    Diagnóstico predictivo industrial y acción social. <a href="#sfa-plataforma" class="text-gold" style="text-decoration: underline; font-weight: 600; transition: color 0.3s;" onmouseover="this.style.color='var(--color-gold-hover)'" onmouseout="this.style.color='var(--color-primary-gold)'">Pruebe gratis el motor Club 33</a>.
                </p>
                
                <div class="ecosistema-grid">
                    <!-- Left Card: Software Avanzado -->
                    <div class="ecosistema-card card-commercial">
                        <div class="card-glow"></div>
                        <h3 class="card-title">SOFTWARE AVANZADO<br><span class="card-subtitle-type">(COMERCIAL)</span></h3>
                        <ul class="card-list">
                            <li class="card-list-item">
                                <span class="item-icon-wrapper">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Diagnóstico SCADA</span>
                            </li>
                            <li class="card-list-item">
                                <span class="item-icon-wrapper">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M12 3c-4.97 0-9 4.03-9 9 0 2.12.74 4.07 1.97 5.61L4.35 19.4c-1.47-1.99-2.35-4.43-2.35-7.07 0-6.63 5.37-12 12-12s12 5.37 12 12c0 2.64-.88 5.08-2.35 7.07l-1.62-1.79C20.26 16.07 21 14.12 21 12c0-4.97-4.03-9-9-9zm0 4c-2.76 0-5 2.24-5 5 0 1.18.41 2.26 1.09 3.11l1.45-1.6C9.25 13.06 9 12.56 9 12c0-1.66 1.34-3 3-3s3 1.34 3 3c0 .56-.25 1.06-.64 1.51l1.45 1.6C16.59 14.26 17 13.18 17 12c0-2.76-2.24-5-5-5zm0 3c-1.1 0-2 .9-2 2 0 .34.08.66.23.94l1.37-1.51c-.04-.04-.08-.09-.08-.15.01-.27.23-.48.5-.48.27 0 .49.21.5.48-.02.06-.06.11-.08.15l1.37 1.51c.15-.28.23-.6.23-.94 0-1.1-.9-2-2-2z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Monitoreo de Sensores</span>
                            </li>
                            <li class="card-list-item">
                                <span class="item-icon-wrapper">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3-.5-3-3s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Industria 4.0</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Right Card: Fundación Áurea -->
                    <div class="ecosistema-card card-social">
                        <div class="card-glow"></div>
                        <h3 class="card-title">FUNDACIÓN ÁUREA<br><span class="card-subtitle-type">(IMPACTO SOCIAL)</span></h3>
                        <ul class="card-list">
                            <li class="card-list-item">
                                <span class="item-icon-wrapper icon-social">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Monitoreo Comunitario</span>
                            </li>
                            <li class="card-list-item">
                                <span class="item-icon-wrapper icon-social">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Eficiencia Energética</span>
                            </li>
                            <li class="card-list-item">
                                <span class="item-icon-wrapper icon-social">
                                    <svg viewBox="0 0 24 24" class="item-icon">
                                        <path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5.89 12.5L12 15.82l6.11-3.32L12 9.18 5.89 12.5z"/>
                                    </svg>
                                </span>
                                <span class="item-text">Academia Áurea</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>


        <!-- MISIÓN Y FILOSOFÍA -->
        <section id="mision" class="content-section alt-bg scroll-reveal">
            <div class="section-container">
                <div class="section-badge">FILOSOFÍA</div>
                <h2 class="section-heading">Nuestra Misión</h2>
                <div class="content-grid">
                    <div class="text-block">
                        <p class="lead-text">
                            En Áurea Systems, creemos que el universo se rige por patrones matemáticos y proporciones armónicas. Nuestra misión es identificar estas estructuras subyacentes para resolver los problemas operativos más complejos de la sociedad y la industria.
                        </p>
                        <p>
                            Utilizando la geometría sagrada y algoritmos avanzados inspirados en la naturaleza, canalizamos la eficiencia matemática para monitorear el desgaste físico, optimizar recursos computacionales y equilibrar flujos financieros de manera sostenible y limpia.
                        </p>
                    </div>
                    <div class="visual-block">
                        <div class="geometric-shape shape-cube">
                            <div class="face front"></div>
                            <div class="face back"></div>
                            <div class="face left"></div>
                            <div class="face right"></div>
                            <div class="face top"></div>
                            <div class="face bottom"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- VISIÓN Y VALORES -->
        <section id="vision" class="content-section scroll-reveal">
            <div class="section-container">
                <div class="section-badge">FUTURO</div>
                <h2 class="section-heading">Nuestra Visión y Valores</h2>
                <div class="content-grid grid-reverse">
                    <div class="text-block">
                        <p class="lead-text">
                            Aspiramos a ser el referente mundial en computación armónica, demostrando que el crecimiento comercial y el impacto social son complementarios.
                        </p>
                        <p>
                            Buscamos un futuro donde los sistemas de información operen en perfecta consonancia con el entorno, minimizando el desperdicio energético, democratizando el acceso a la educación tecnológica y respondiendo con precisión ante crisis humanitarias mundiales.
                        </p>
                    </div>
                    <div class="visual-block">
                        <div class="geometric-shape shape-octahedron">
                            <div class="triangle t1"></div>
                            <div class="triangle t2"></div>
                            <div class="triangle t3"></div>
                            <div class="triangle t4"></div>
                            <div class="triangle t5"></div>
                            <div class="triangle t6"></div>
                            <div class="triangle t7"></div>
                            <div class="triangle t8"></div>
                        </div>
                    </div>
                </div>

                <div class="valores-grid" style="margin-top: 5rem;">
                    <div class="valor-card">
                        <div class="valor-header">
                            <span class="valor-num text-gold">01</span>
                            <h3>Economía Analítica</h3>
                        </div>
                        <p>Resolvemos la complejidad con la mínima cantidad de recursos informáticos y operativos. Honramos el código lineal en un solo hilo: la verdadera inteligencia es ligera y no requiere de fuerza bruta ni desperdicio energético.</p>
                    </div>
                    <div class="valor-card">
                        <div class="valor-header">
                            <span class="valor-num text-gold">02</span>
                            <h3>Enfoque Estoico</h3>
                        </div>
                        <p>Operamos bajo la fría precisión de nuestro algoritmo. El núcleo humano aprende a ignorar la estática, el pánico del mercado y las fluctuaciones externas para concentrarse únicamente en el control directo.</p>
                    </div>
                    <div class="valor-card">
                        <div class="valor-header">
                            <span class="valor-num text-gold">03</span>
                            <h3>Propósito Consecuente</h3>
                        </div>
                        <p>El éxito de nuestras licencias comerciales es un medio, no un fin. La riqueza pertenece al desarrollo social; medimos nuestro éxito en infraestructura civil protegida, mentes inspiradas y tecnologías de diagnóstico limpio, no en capital acumulado.</p>
                    </div>
                    <div class="valor-card">
                        <div class="valor-header">
                            <span class="valor-num text-gold">04</span>
                            <h3>Armonía Geométrica</h3>
                        </div>
                        <p>Respetamos las proporciones intrínsecas de la naturaleza (Proporción Áurea y la sucesión de Fibonacci) como guías maestras. Si un proceso de ingeniería altera el orden natural del entorno, es inmediatamente descartado.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- TECNOLOGÍA SFA Y CASOS DE USO -->
        <section id="servicios" class="content-section alt-bg scroll-reveal">
            <div class="section-container">
                <div class="section-badge">TECNOLOGÍA</div>
                <h2 class="section-heading">Motor SFA en Plantas Industriales</h2>
                <p class="section-intro">
                    Procesamos ráfagas continuas de telemetría de sensores y Controladores Lógicos Programables (PLCs) para predecir fallas mediante análisis espectral y filtros de atenuación de ruido fractal.
                </p>

                <!-- 3 Layers of Architecture -->
                <div class="architecture-flow">
                    <h3 class="flow-title">Arquitectura de Conexión de Datos</h3>
                    <div class="flow-grid">
                        <div class="flow-step">
                            <div class="step-num">Capa 1</div>
                            <h4>Captura (Sensores)</h4>
                            <p>Variables físicas capturadas en tiempo real en motores y bombas mediante sensores analógicos e inteligentes (protocolos IO-Link, HART).</p>
                        </div>
                        <div class="flow-arrow">➔</div>
                        <div class="flow-step">
                            <div class="step-num">Capa 2</div>
                            <h4>Concentración (PLCs)</h4>
                            <p>PLCs de planta (Allen-Bradley, Siemens, Omron) empaquetan registros y los transmiten por buses industriales (Modbus TCP/IP, OPC UA, MQTT).</p>
                        </div>
                        <div class="flow-arrow">➔</div>
                        <div class="flow-step">
                            <div class="step-num">Capa 3</div>
                            <h4>Procesamiento SFA <span class="tooltip-trigger" data-tooltip-text="Algoritmo que descompone señales temporales en componentes auto-similares para identificar fatigas mecánicas imperceptibles para Fourier standard.">?</span></h4>
                            <p>Nuestro motor analiza el torrente de datos crudos aplicando atenuación de ruido fractal para diagnosticar la salud de la maquinaria.</p>
                        </div>
                    </div>
                </div>


                <!-- El simulador logístico ha sido removido de la interfaz para enfoque exclusivo en SCADA -->
                <h3 class="table-section-title">Matriz de Variables de Sensores y Respuestas SFA</h3>
                <div class="table-responsive-wrapper">
                    <table class="matrix-table">
                        <thead>
                            <tr>
                                <th>Tipo de Sensor</th>
                                <th>Variable de Registro en PLC</th>
                                <th>Frecuencia Analizada</th>
                                <th>Acción Correctiva / Predictiva SFA</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="font-bold text-white">Acelerómetros (Vibración)</td>
                                <td>Entrada Analógica Rápida</td>
                                <td><span class="badge badge-high">Alta (kHz)</span></td>
                                <td>Detección de micro-fisuras en rodamientos y holguras mecánicas.</td>
                            </tr>
                            <tr>
                                <td class="font-bold text-white">Transmisores de Presión</td>
                                <td>Registro Modbus / Palabra IW</td>
                                <td><span class="badge badge-medium">Media (Hz)</span></td>
                                <td>Identificación de picos transitorios y golpes de ariete.</td>
                            </tr>
                            <tr>
                                <td class="font-bold text-white">Sensores de Corriente (CTs)</td>
                                <td>Datos de Variador vía OPC UA</td>
                                <td><span class="badge badge-medium">50 / 60 Hz + Armónicos</span></td>
                                <td>Diagnóstico de fallas en barras del rotor y desequilibrio de fases.</td>
                            </tr>
                            <tr>
                                <td class="font-bold text-white">Termocoples / RTD (Temp)</td>
                                <td>Bloque de Datos Común (DB)</td>
                                <td><span class="badge badge-low">Baja (Ciclos/min)</span></td>
                                <td>Modelado de fatiga térmica y deriva de calibración del sensor.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
